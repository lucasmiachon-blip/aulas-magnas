# === Transcribe Pipeline ===

# Anthropic (obrigatório para análise)
ANTHROPIC_API_KEY=

# Notion (opcional — só se usar --notion)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Whisper (opcionais — defaults no script)
WHISPER_MODEL=medium
WHISPER_LANGUAGE=pt

# === MCP Servers ===

# PubMed (opcional — aumenta rate limit de 3 para 10 req/s)
NCBI_API_KEY=

# PubMed Simple (Python) — obrigatório para pubmed-simple; pubmed (Node) usa scripts/run-pubmed-mcp.js
PUBMED_EMAIL=

# Zotero — busca refs na biblioteca (opcional)
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=

# Semantic Scholar — grátis sem key. Com key: limits maiores
# Obter em: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Perplexity — requer assinatura paga
# Obter em: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Notion MCP (se usar o MCP server além do script)
NOTION_TOKEN=

# === Notion Workspace IDs ===
# Não são secrets, mas externalizados para higiene do repo.
# Referência canônica — docs/SYNC-NOTION-REPO.md aponta aqui.
NOTION_SLIDES_DB_ID=620431d1-8955-42b7-8b04-8f7cc616a8ab
NOTION_SLIDES_DATA_SOURCE_ID=c6713964-0b31-454f-83f5-4b287911a01b
NOTION_REFS_DB_ID=9340cdc0-7c59-4566-81a2-6b5c6b4e7b5d
NOTION_REFS_DATA_SOURCE_ID=2b24bb6c-91be-42c0-ae28-908a794e5cf5
NOTION_BLUEPRINT_CIRROSE_ID=30adfe68-59a8-815a-abf5-c817cd705b29
NOTION_BLUEPRINT_META_ID=30adfe68-59a8-81d2-b1f6-c81c59e3e12d
NOTION_BIBLIA_NARRATIVA_ID=311dfe68-59a8-816b-b9c0-ec10eccfb235
NOTION_DASHBOARD_CIRROSE_ID=311dfe68-59a8-81dd-b88d-ddf52560d5bc

# === MCP Output ===
MAX_MCP_OUTPUT_TOKENS=15000
