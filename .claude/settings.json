{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git stash*)",
      "Bash(git fetch*)",
      "Bash(git checkout*)",
      "Bash(git restore*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git merge*)",
      "Bash(git check-*)",
      "Bash(git remote*)",
      "Bash(git worktree*)",
      "Bash(git -C *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(pwd*)",
      "Bash(xxd *)",
      "Bash(curl *)",
      "Bash(for *)",
      "Bash(bash *)",
      "Bash(powershell *)",
      "Bash(python *)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -df*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|StrReplace",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-evidence-db.sh",
            "timeout": 15,
            "statusMessage": "Verificando evidence-db..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-evidence-db.sh",
            "timeout": 5,
            "statusMessage": "Verificando permissão evidence-db..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-shared.sh",
            "timeout": 5,
            "statusMessage": "Verificando permissão shared/..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-merge.sh",
            "timeout": 10,
            "statusMessage": "Validando merge..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-secrets.sh",
            "timeout": 10,
            "statusMessage": "Escaneando secrets..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/warn-class-c.sh",
            "timeout": 10,
            "statusMessage": "Verificando Class C..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/build-monitor.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/audit-trail.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/build-monitor.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/audit-trail.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/subagent-stop-log.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-tracker.sh session-start",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-compact-reinject.sh",
            "timeout": 10,
            "statusMessage": "Re-injetando contexto pós-compact..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session-tracker.sh session-compact",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-tracker.sh session-end",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
