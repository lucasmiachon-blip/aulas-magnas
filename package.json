{
  "name": "aulas-magnas",
  "version": "7.0.0",
  "description": "Aulas magnas para congressos — Reveal.js + GSAP + OKLCH",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:grade": "vite --open /aulas/grade/index.html",
    "dev:cirrose": "vite --open /aulas/cirrose/index.html",
    "dev:metanalise": "vite --open /aulas/metanalise/index.html",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "fonts:install": "node scripts/install-fonts.js",
    "lint:slides": "node scripts/lint-slides.js",
    "lint:case-sync": "node scripts/lint-case-sync.js",
    "lint:narrative-sync": "node scripts/lint-narrative-sync.js",
    "export:pdf": "node scripts/export-pdf.js",
    "export:screenshots": "node scripts/export-screenshots.js",
    "qa:a11y": "node scripts/qa-accessibility.js",
    "qa:screenshots:cirrose": "node aulas/cirrose/scripts/qa-screenshots-stage-c.js",
    "build:cirrose": "powershell -ExecutionPolicy Bypass -File aulas/cirrose/scripts/build-html.ps1",
    "build:grade": "powershell -ExecutionPolicy Bypass -File aulas/grade/scripts/build-html.ps1",
    "build:osteoporose": "powershell -ExecutionPolicy Bypass -File aulas/osteoporose/scripts/build-html.ps1",
    "dev:osteoporose": "vite --open /aulas/osteoporose/index.html",
    "zip:ia": "./scripts/build-zip-limpo-ia.ps1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@axe-core/playwright": "^4.11.1",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@notionhq/client": "^2.3.0",
    "axe-core": "^4.11.1",
    "decktape": "^3.14.0",
    "dotenv": "^16.4.0",
    "playwright": "^1.58.2",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "gsap": "^3.12.5",
    "reveal.js": "~5.2.1"
  }
}
